{
  "name": "trans-bulki",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "env:local": "node scripts/use-env.mjs development",
    "env:prod": "node scripts/use-env.mjs production",
    "start": "expo start",
    "start:local": "node scripts/use-env.mjs development && expo start -c",
    "start:prod": "node scripts/use-env.mjs production && expo start -c",
    "android": "expo start --android",
    "android:local": "node scripts/use-env.mjs development && expo start --android -c",
    "android:prod": "node scripts/use-env.mjs production && expo start --android -c",
    "ios": "expo start --ios",
    "ios:local": "node scripts/use-env.mjs development && expo start --ios -c",
    "ios:prod": "node scripts/use-env.mjs production && expo start --ios -c",
    "web": "expo start --web",
    "web:local": "node scripts/use-env.mjs development && expo start --web -c",
    "web:prod": "node scripts/use-env.mjs production && expo start --web -c",
    "build:web": "expo export -p web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "leaflet": "^1.9.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
