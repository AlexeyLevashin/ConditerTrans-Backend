# Переключение окружения:
#   npm run env:local     → копирует .env.development в .env
#   npm run env:prod      → копирует .env.production в .env
#
# Запуск:
#   npm run start:local
#   npm run start:prod

# development | production
EXPO_PUBLIC_APP_ENV=development

# ConditerTrans Backend API
EXPO_PUBLIC_API_URL=http://localhost:8080/api

# Logistic Service — GPS tracking (HTTP/WS через nginx: /logistic-service)
EXPO_PUBLIC_TRACKING_WS_URL=ws://localhost/logistic-service

# Frontend URL for invite links
EXPO_PUBLIC_APP_URL=http://localhost:8081
